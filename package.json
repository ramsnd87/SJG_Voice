{
  "name": "glitch-studio-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone voice-cloning + clip-prep studio. Reads from external engines (EnginSam TTS, ffmpeg). Does not modify any other project.",
  "main": "src/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,SIDECAR,ELECTRON -c blue,magenta,green \"npm:dev:vite\" \"npm:dev:sidecar\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:sidecar": "node src/sidecar/index.mjs",
    "dev:electron": "wait-on http://127.0.0.1:5193 && cross-env GSB_DEV=1 electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "test": "node --test tests"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
